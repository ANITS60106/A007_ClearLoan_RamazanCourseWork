DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=*

# Optional SMTP (leave EMAIL_BACKEND default for console emails)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=1

# Where to send a copy of applications (for demo testing)
DEMO_APPLICATIONS_EMAIL=ramazan.almazbekov@alatoo.edu.kg

# --- Production (Koyeb) recommended ---
# Set DEBUG off in production
DJANGO_DEBUG=0

# Your public app URL for CSRF (comma-separated). Example:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.koyeb.app
DJANGO_CSRF_TRUSTED_ORIGINS=

# Allow your hostnames (comma-separated). Example:
# DJANGO_ALLOWED_HOSTS=your-app.koyeb.app,*.koyeb.app
DJANGO_ALLOWED_HOSTS=*

# Postgres connection string (recommended). Example:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# CORS for Flutter Web (1 = allow all origins for prototype)
CORS_ALLOW_ALL_ORIGINS=1

# Optional: seed demo data on every deploy (creates 25 demo users + banks)
SEED_DEMO=0

# Gunicorn tuning
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=60
